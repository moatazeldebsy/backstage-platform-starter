{
  "name": "${{ values.name }}",
  "version": "0.1.0",
  "description": "${{ values.description }}",
  "private": true,
  "scripts": {
    "test": "jest --testPathPattern=consumer",
    "verify": "jest --testPathPattern=provider",
    "publish": "pact-broker publish ./pacts --consumer-app-version=$(git rev-parse --short HEAD) --broker-base-url=${{ values.pactBrokerUrl }}"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^12.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}
