{
  "name": "${{ values.name }} - API health check",
  "type": "api",
  "subtype": "http",
  "status": "live",
  "tags": [
    "service:${{ values.name }}",
    "team:${{ values.owner }}",
    "env:production"
  ],
  "locations": ${{ values.locations | dump }},
  "options": {
    "tick_every": 300,
    "min_failure_duration": 0,
    "min_location_failed": 1,
    "retry": {
      "count": 2,
      "interval": 300
    },
    "monitor_options": {
      "notify_audit": false,
      "include_tags": true
    }
  },
  "config": {
    "request": {
      "method": "GET",
      "url": "${{ values.targetUrl }}/healthz",
      "timeout": 30
    },
    "assertions": [
      {
        "type": "statusCode",
        "operator": "is",
        "target": 200
      },
      {
        "type": "responseTime",
        "operator": "lessThan",
        "target": 2000
      }
    ]
  }
}
