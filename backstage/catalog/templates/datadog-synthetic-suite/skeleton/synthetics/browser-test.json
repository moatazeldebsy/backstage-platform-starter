{
  "name": "${{ values.name }} - Browser journey",
  "type": "browser",
  "status": "paused",
  "tags": [
    "service:${{ values.name }}",
    "team:${{ values.owner }}",
    "env:production"
  ],
  "locations": ${{ values.locations | dump }},
  "options": {
    "tick_every": 3600,
    "min_failure_duration": 0,
    "min_location_failed": 1,
    "device_ids": ["laptop_large"],
    "retry": {
      "count": 1,
      "interval": 300
    }
  },
  "config": {
    "request": {
      "method": "GET",
      "url": "${{ values.targetUrl }}"
    },
    "steps": []
  },
  "_note": "Record browser steps in the Datadog UI, then export and replace the steps array above."
}
