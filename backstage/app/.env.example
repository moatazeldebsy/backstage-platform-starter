# Backstage app .env for local development (yarn start / yarn start-backend)
# Copy to .env and fill in values before running locally (without Docker)

# ── GitHub Personal Access Token ─────────────────────────────────────────────
# Required for scaffolder templates and catalog import
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── GitHub OAuth App ────────────────────────────────────────────────────────
# Enables "Sign in with GitHub" on the Backstage login screen
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# ── Backstage auth secret ──────────────────────────────────────────────────
# Used by the Backstage token service to sign session cookies (required in v1.29+)
# For local dev any non-empty string works; for production use: openssl rand -hex 32
BACKSTAGE_AUTH_SECRET=dev-secret-local

# ── Kubernetes plugin (optional) ────────────────────────────────────────────
# Auto-populated by scripts/get-k8s-credentials.sh
K8S_CLUSTER_URL=
K8S_SERVICE_ACCOUNT_TOKEN=
K8S_CLUSTER_CA_DATA=

# ── AWS (optional) ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
TECHDOCS_S3_BUCKET_NAME=

# ── Platform identity ───────────────────────────────────────────────────────
GITHUB_ORG=YOUR_GITHUB_ORG
