FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod ./
RUN go mod download
COPY src/ ./src/
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /service ./src/...

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /service /service
EXPOSE <% .Port %>
ENTRYPOINT ["/service"]
