replicaCount: 1

image:
  repository: ghcr.io/<% .GHOrg %>/<% .Name %>
  tag: "latest"
  pullPolicy: IfNotPresent

service:
  port: 80
  targetPort: <% .Port %>

ingress:
  enabled: true
  className: nginx
  hosts:
    - host: <% .Name %>-dev.idp.local
      paths:
        - path: /
          pathType: Prefix

resources:
  requests:
    cpu: 25m
    memory: 32Mi
  limits:
    cpu: 100m
    memory: 64Mi

env:
  - name: ENVIRONMENT
    value: dev
