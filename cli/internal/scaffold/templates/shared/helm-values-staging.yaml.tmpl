replicaCount: 2

image:
  repository: ghcr.io/<% .GHOrg %>/<% .Name %>
  tag: "latest"
  pullPolicy: IfNotPresent

service:
  port: 80
  targetPort: <% .Port %>

ingress:
  enabled: true
  className: nginx
  hosts:
    - host: <% .Name %>-staging.idp.local
      paths:
        - path: /
          pathType: Prefix

resources:
  requests:
    cpu: 50m
    memory: 64Mi
  limits:
    cpu: 200m
    memory: 128Mi

env:
  - name: ENVIRONMENT
    value: staging
