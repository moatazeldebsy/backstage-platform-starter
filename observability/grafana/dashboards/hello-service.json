{
  "title": "IDP Services Overview",
  "uid": "idp-services",
  "tags": [
    "idp",
    "services"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_pod_info{namespace=~\"services.*\"}, namespace)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": "services.*",
        "current": {},
        "hide": 0,
        "sort": 1
      },
      {
        "name": "service",
        "label": "Service (from Backstage Catalog)",
        "description": "Dynamically populated from the Backstage catalog via backstage_catalog_service_info metric. New services appear automatically within 5 minutes of registration.",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(backstage_catalog_service_info, name)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "current": {},
        "hide": 0,
        "sort": 1
      },
      {
        "name": "owner",
        "label": "Owner / Team",
        "description": "Filter by team owner \u2014 sourced from the Backstage catalog.",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(backstage_catalog_service_info, owner)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {},
        "hide": 0,
        "sort": 1
      },
      {
        "name": "cost_center",
        "label": "Cost Center",
        "description": "Filter by cost center for OpenCost attribution.",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(backstage_catalog_service_info, cost_center)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {},
        "hide": 0,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "title": "Registered Services (Backstage Catalog)",
      "description": "Live list of services registered in Backstage. Updated every 5 minutes by the backstage-catalog-exporter CronJob.",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "backstage_catalog_service_info{owner=~\"$owner\", cost_center=~\"$cost_center\"}",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns",
            "keepLabels": [
              "name",
              "owner",
              "lifecycle",
              "system",
              "cost_center"
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Service",
              "owner": "Owner",
              "lifecycle": "Lifecycle",
              "system": "System",
              "cost_center": "Cost Center"
            },
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "job": true,
              "instance": true
            }
          }
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Service",
            "desc": false
          }
        ],
        "footer": {
          "show": true,
          "reducer": [
            "count"
          ],
          "fields": [
            "Service"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Lifecycle"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "development": {
                        "text": "development",
                        "color": "blue",
                        "index": 0
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "production": {
                        "text": "production",
                        "color": "green",
                        "index": 1
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "deprecated": {
                        "text": "deprecated",
                        "color": "red",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "Kubernetes Pods Inventory",
      "description": "All pods running in services namespaces \u2014 updated automatically as new services are deployed.",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "kube_pod_info{namespace=~\"$namespace\"}",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns",
            "keepLabels": [
              "namespace",
              "pod",
              "node",
              "created_by_name",
              "created_by_kind"
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "namespace": "Namespace",
              "pod": "Pod",
              "node": "Node",
              "created_by_name": "Controller",
              "created_by_kind": "Kind"
            },
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true
            }
          }
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Namespace",
            "desc": false
          }
        ],
        "footer": {
          "show": true,
          "reducer": [
            "count"
          ],
          "fields": [
            "Pod"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Namespace"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Pod"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 300
              }
            ]
          }
        ]
      }
    },
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{namespace=~\"$namespace\"}[5m])) by (namespace, pod)",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", container!=\"\"}[5m])) by (namespace, pod)",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\", container!=\"\"}) by (namespace, pod)",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Pod Restarts",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}) by (namespace, pod)",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "title": "Per-Service Drill-Down \u2014 $service",
      "type": "row",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "panels": [
        {
          "id": 21,
          "title": "HTTP Request Rate \u2014 $service",
          "description": "Request rate for pods matching backstage.io/kubernetes-id=$service label.",
          "type": "timeseries",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 33
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum(rate(http_requests_total{namespace=~\"services.*\", pod=~\"$service.*\"}[5m])) by (pod)",
              "legendFormat": "{{pod}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqps",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 22,
          "title": "CPU Usage \u2014 $service",
          "type": "timeseries",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 33
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"services.*\", pod=~\"$service.*\", container!=\"\"}[5m])) by (pod)",
              "legendFormat": "{{pod}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percentunit",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 23,
          "title": "Memory Usage \u2014 $service",
          "type": "timeseries",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 41
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum(container_memory_working_set_bytes{namespace=~\"services.*\", pod=~\"$service.*\", container!=\"\"}) by (pod)",
              "legendFormat": "{{pod}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "bytes",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 24,
          "title": "Pod Restarts \u2014 $service",
          "type": "stat",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 41
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"services.*\", pod=~\"$service.*\"}) by (pod)",
              "legendFormat": "{{pod}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 3
                  },
                  {
                    "color": "red",
                    "value": 10
                  }
                ]
              }
            }
          }
        },
        {
          "id": 25,
          "title": "Catalog Info \u2014 $service",
          "description": "Service metadata from Backstage catalog.",
          "type": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "gridPos": {
            "h": 4,
            "w": 24,
            "x": 0,
            "y": 49
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "backstage_catalog_service_info{name=\"$service\"}",
              "instant": true,
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "transformations": [
            {
              "id": "labelsToFields",
              "options": {
                "mode": "columns",
                "keepLabels": [
                  "name",
                  "owner",
                  "lifecycle",
                  "system",
                  "cost_center"
                ]
              }
            },
            {
              "id": "organize",
              "options": {
                "renameByName": {
                  "name": "Service",
                  "owner": "Owner",
                  "lifecycle": "Lifecycle",
                  "system": "System",
                  "cost_center": "Cost Center"
                },
                "excludeByName": {
                  "Time": true,
                  "Value": true,
                  "__name__": true,
                  "job": true,
                  "instance": true
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
