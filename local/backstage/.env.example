# Copy to .env and fill in values before running docker compose.
# Run setup.sh or ./scripts/get-k8s-credentials.sh to auto-populate K8s vars.

# ── GitHub Personal Access Token (PAT) ──────────────────────────────────────
# Same token as local/.env — needed by scaffolder templates and catalog import.
# Create at: https://github.com/settings/tokens
#   Token type : Classic
#   Required scopes: repo, read:org, workflow, delete_repo
GITHUB_TOKEN=

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Enables "Sign in with GitHub" on the Backstage login screen.
# Without this, only Guest mode works.
#
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
#   Application name : IDP Dev Portal (local)
#   Homepage URL     : http://localhost:3000
#   Callback URL     : http://localhost:3000/api/auth/github/handler/frame
#
# After creating, copy the Client ID here and generate a Client Secret:
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# ── Backstage auth secret ─────────────────────────────────────────────────────
# Used by the Backstage token service to sign session cookies (required in v1.29+).
# For local dev any non-empty string works; leave blank to use the built-in default.
# In production use a cryptographically random 32-byte hex string:
#   openssl rand -hex 32
BACKSTAGE_AUTH_SECRET=

# ── K8s plugin ───────────────────────────────────────────────────────────────
# Auto-populated by scripts/get-k8s-credentials.sh — do NOT set manually.
K8S_CLUSTER_URL=
K8S_SERVICE_ACCOUNT_TOKEN=
K8S_CLUSTER_CA_DATA=

# ── ArgoCD ───────────────────────────────────────────────────────────────────
# Auto-populated by bootstrap-local.sh — ArgoCD initial admin password.
ARGOCD_AUTH_TOKEN=

# ── Grafana ───────────────────────────────────────────────────────────────────
# Auto-populated by bootstrap-local.sh — Grafana Viewer service account token.
GRAFANA_TOKEN=

# ── AWS / TechDocs (only needed if publishing docs to S3) ────────────────────
AWS_REGION=us-east-1
TECHDOCS_S3_BUCKET_NAME=
