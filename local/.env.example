# Copy to .env and fill in values before running local scripts.
# Shared settings used by bootstrap scripts and tooling.
# Backstage-specific tokens (OAuth, K8s) go in local/backstage/.env.

# ── Platform identity (written by setup.sh — do not edit manually) ──────────
GITHUB_ORG=YOUR_GITHUB_ORG
PLATFORM_REPO=backstage-idp-starter

# ── GitHub Personal Access Token (PAT) ──────────────────────────────────────
# Required for:
#   - Scaffolder templates to create/push repositories on your behalf
#   - DORA metrics exporter to read commit/PR data
#   - Catalog import from GitHub
#
# Create at: https://github.com/settings/tokens
#   Token type : Classic
#   Required scopes: repo, read:org, workflow, delete_repo
#   Expiry: set to at least 90 days (or "No expiration" for local dev)
GITHUB_TOKEN=

# ── AWS credentials (only needed for TechDocs S3 or ECR pushes) ─────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Local Kind cluster name (default matches setup.sh) ──────────────────────
CLUSTER_NAME=idp-mvp

# ── Anthropic Claude API (used by KAgent IDP assistant) ─────────────────────
# Required for AI agents — powers the KAgent IDP assistant (Claude Haiku).
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Slack notifications (optional) ──────────────────────────────────────────
# Enables AlertManager → Slack routing for platform alerts.
# Create an Incoming Webhook at https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=
